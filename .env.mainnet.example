# Core runtime
NODE_ENV=production
OPS_BASE=https://arena-mainnet.panchoverse.com
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/BXGTE6XP8kfGGwodSZ3dI
NEXT_PUBLIC_SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/BXGTE6XP8kfGGwodSZ3dI

# App mode switches
NEXT_PUBLIC_SIM_MODE=false
NEXT_PUBLIC_USE_ONCHAIN_PROGRAM=true
PANCHO_PRELAUNCH_ONCHAIN=true

# Program/wallets
PANCHO_PROGRAM_ID=REPLACE_WITH_MAINNET_PROGRAM_ID
NEXT_PUBLIC_PANCHO_PROGRAM_ID=REPLACE_WITH_MAINNET_PROGRAM_ID
PANCHO_TREASURY_WALLET=418cSB954o9jaYeDRFj3CFWzzLNkTERwY2h8ErHEgvzR
TREASURY_WALLET=418cSB954o9jaYeDRFj3CFWzzLNkTERwY2h8ErHEgvzR
PANCHO_EXPECTED_TREASURY_WALLET=418cSB954o9jaYeDRFj3CFWzzLNkTERwY2h8ErHEgvzR
PANCHO_INITIAL_ADMIN_WALLET=6X8KQrJ87ekdeUaxwR38fRtrhhDr1ZE4PSc1GsGRqTfe
NEXT_PUBLIC_ESCROW_WALLET=REPLACE_WITH_ESCROW_WALLET

# Keeper signer
PANCHO_KEEPER_KEYPAIR_PATH=/absolute/path/to/keeper.json
# PANCHO_KEEPER_SECRET_KEY=[...]

# On-chain oracle accounts
PANCHO_ORACLE_PROGRAM_ID=REPLACE_WITH_ORACLE_PROGRAM_ID
PANCHO_ORACLE_ACCOUNT_SOL=REPLACE_WITH_SOL_ORACLE_ACCOUNT
PANCHO_ORACLE_ACCOUNT_BTC=REPLACE_WITH_BTC_ORACLE_ACCOUNT
PANCHO_ORACLE_ACCOUNT_ETH=REPLACE_WITH_ETH_ORACLE_ACCOUNT

# Fees/timing (fee is immutable on-chain at 600 bps)
PANCHO_OPEN_SECONDS=60
PANCHO_LOCK_SECONDS=60
PANCHO_SETTLEMENT_SECONDS=300
PANCHO_ORACLE_MAX_AGE_SEC=120

# API keys / ops secrets
SETTLE_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY
SIM_SETTLE_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY
OPS_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY

# Launch safety flags (must be off for launch)
PANCHO_PAUSE_JOINS=off
PANCHO_PAUSE_SIM_SETTLEMENTS=off
PANCHO_PAUSE_SETTLE_API=off

# Optional launch checks
PRELAUNCH_SKIP_SMOKE=false
